# .claudeignore
# Prevents Claude from reading irrelevant files — keeps context lean and fast.
# Reduces startup token usage significantly on this project.

# ─── Python Environment ──────────────────────────────────────────
.venv/
venv/
__pycache__/
*.pyc
*.pyo
*.pyd
__pypackages__/
*.egg-info/
dist/
build/

# ─── Generated Output (ebooks & archives) ────────────────────────
output/
*.epub
*.azw3
*.mobi
*.pdf

# ─── Temporary / Scratch ─────────────────────────────────────────
temp/
tmp/
.temp/
*.log
logs/

# ─── Static Reference Data (read-only, never modify) ─────────────
# JLPT kanji lists are authoritative — Claude should not read or edit them
data/jlpt_kanji/

# ─── Version Control ─────────────────────────────────────────────
.git/

# ─── IDE & Editor ────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ─── Environment & Secrets ───────────────────────────────────────
.env
.env.local
*.pem
*.key
secrets/

# ─── Large / Binary Data ─────────────────────────────────────────
*.zip
*.tar.gz
*.jpg
*.png
*.jpeg

# ─── Lock Files ──────────────────────────────────────────────────
poetry.lock
Pipfile.lock
requirements*.txt.lock
